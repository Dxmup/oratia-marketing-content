  "x_posts": [
    {"id":"post_1","type":"sharp_opinion","source_theme":"context_before_solution","text":"If the owner does not understand why the old approach stopped working, your pitch just sounds like another manager reading features off a menu.","engagement_prompt":false,"post_role":"sharpest_observation","best_timing":"early_week","publish_after_linkedin":false,"source_trace":{"book_slug":"sales_pitch","source_file":"linkedin/post_1.txt","theme":"context_before_solution","related_linkedin_post":"linkedin/post_1.txt"}},
    {"id":"post_2","type":"recognition","source_theme":"failed_alternatives","text":"A lot of acquisition teams are still selling against one alternative. In VRM you usually need to de-position both self-management and the big-box manager.","engagement_prompt":false,"post_role":"recognition_line","best_timing":"mid_week","publish_after_linkedin":true,"source_trace":{"book_slug":"sales_pitch","source_file":"linkedin/post_2.txt","theme":"failed_alternatives","related_linkedin_post":"linkedin/post_2.txt"}},
    {"id":"post_3","type":"recognition","source_theme":"capability_translation","text":"'24/7 guest communication' is a feature. 'You do not get the 2 AM locked-out guest call' is the thing the owner actually buys.","engagement_prompt":false,"post_role":"recognition_line","best_timing":"mid_week","publish_after_linkedin":true,"source_trace":{"book_slug":"sales_pitch","source_file":"linkedin/post_3.txt","theme":"capability_translation","related_linkedin_post":"linkedin/post_3.txt"}},
    {"id":"post_4","type":"diagnostic","source_theme":"market_shift_opening","text":"Good pitch prep starts with one question: what changed in this market recently that makes the old way of managing materially worse than it used to be?","engagement_prompt":false,"post_role":"tactical_question","best_timing":"after_post_1","publish_after_linkedin":true,"source_trace":{"book_slug":"sales_pitch","source_file":"newsletter/newsletter.txt","theme":"market_shift_opening","related_linkedin_post":"linkedin/post_1.txt"}},
    {"id":"post_5","type":"story_detail","source_theme":"structural_limitations","text":"The cleanest de-positioning line against big-box firms is usually not emotional at all. It's just math: too many properties per local manager means your home gets half an hour of real attention a week, if that.","engagement_prompt":false,"post_role":"story_detail","best_timing":"mid_week","publish_after_linkedin":true,"source_trace":{"book_slug":"sales_pitch","source_file":"newsletter/newsletter.txt","theme":"structural_limitations","related_linkedin_post":"linkedin/post_2.txt"}},
    {"id":"post_6","type":"engagement","source_theme":"feature_to_outcome_gap","text":"What feature do you think VRMs most often fail to translate into owner-level value: pricing tech, maintenance, guest comms, or direct booking?","engagement_prompt":true,"post_role":"conversation_opener","best_timing":"late_week","publish_after_linkedin":true,"source_trace":{"book_slug":"sales_pitch","source_file":"newsletter/newsletter.txt","theme":"feature_to_outcome_gap","related_linkedin_post":"linkedin/post_3.txt"}},
    {"id":"post_7","type":"channel_connector","source_theme":"vrm_sales_library_bridge","text":"Went deeper on this in the VRM Sales Library because context-first positioning does a lot of work before your capabilities ever have to defend themselves.","engagement_prompt":false,"post_role":"cross_channel_bridge","best_timing":"end_of_week","publish_after_linkedin":true,"source_trace":{"book_slug":"sales_pitch","source_file":"newsletter/newsletter.txt","theme":"vrm_sales_library_bridge","related_linkedin_post":"linkedin/post_1.txt"}}
