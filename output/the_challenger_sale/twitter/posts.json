    {"id":"post_1","type":"sharp_opinion","source_theme":"relationship_builder_limit","text":"Being likable is useful. Being the only manager who taught the owner something they didn't already know is what survives the comparison round.","engagement_prompt":false,"post_role":"sharpest_observation","best_timing":"early_week","publish_after_linkedin":false,"source_trace":{"book_slug":"the_challenger_sale","source_file":"linkedin/post_1.txt","theme":"relationship_builder_limit","related_linkedin_post":"linkedin/post_1.txt"}},
    {"id":"post_2","type":"recognition","source_theme":"teach_tailor_take_control","text":"Many VRM pitches stay polite all the way to the close and never create enough value tension for the owner to see you as anything but another option.","engagement_prompt":false,"post_role":"recognition_line","best_timing":"mid_week","publish_after_linkedin":true,"source_trace":{"book_slug":"the_challenger_sale","source_file":"newsletter/newsletter.txt","theme":"teach_tailor_take_control","related_linkedin_post":"linkedin/post_1.txt"}},
    {"id":"post_3","type":"diagnostic","source_theme":"insight_inventory","text":"When your opening insight could apply to any market in America, it's not a Challenger insight yet. It needs a block, a comp set, or a pattern the owner can verify.","engagement_prompt":false,"post_role":"tactical_question","best_timing":"after_post_1","publish_after_linkedin":true,"source_trace":{"book_slug":"the_challenger_sale","source_file":"newsletter/newsletter.txt","theme":"insight_inventory","related_linkedin_post":"linkedin/post_1.txt"}},
